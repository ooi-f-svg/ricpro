 media=\\\"(min-width: 769px)\\\" srcset=\\\"https://www.ricpro.com/images/rnwl/naisou/cnt_contact05_pc.png\\\">\\n              <img class=\\\"cnt-contact__image\\\" src=\\\"https://www.ricpro.com/images/rnwl/naisou/cnt_contact05_sp.png\\\" alt=\\\"リフォームに関するLINEでのご相談はこちら\\\">\\n            </picture>\\n          </a>\\n        </div>\\n        <div class=\\\"cnt-contact__item cnt-contact__item--wide cnt-contact__item--sp\\\">\\n          <a class=\\\"cnt-contact__link\\\" href=\\\"https://www.ricpro.com/ffex/index.php?form=naisou_inquiry\\\">\\n            <img class=\\\"cnt-contact__image\\\" src=\\\"https://www.ricpro.com/images/rnwl/naisou/cnt_contact03_sp.png\\\" alt=\\\"リフォームに関するメールでの問合せはこちら\\\">\\n          </a>\\n        </div>\\n      </div>\\n    </div>\\n  </div>\\n\",\n  \"reasons\": \"\\n        <div class=\\\"reasons-inner\\\">\\n          <div class=\\\"section-title\\\">\\n            <h2>選ばれる理由</h2>\\n            <img src=\\\"https://www.ricpro.com/images/rnwl/main/ricproman.png\\\" alt=\\\"リックプロマン\\\" class=\\\"section-illust\\\">\\n          </div>\\n          <div class=\\\"reasons-list\\\">\\n            <div class=\\\"reason-card\\\">\\n              <div class=\\\"reason-card-inner\\\">\\n                <div class=\\\"reason-card-bg\\\">\\n                  <img src=\\\"https://www.ricpro.com/images/rnwl/main/reason2.png\\\" alt=\\\"グループ一貫体制\\\">\\n                </div>\\n                <div class=\\\"reason-card-content\\\">\\n                  <div class=\\\"reason-card-header\\\">\\n                    <div class=\\\"reason-card-num\\\">01</div>\\n                    <div class=\\\"reason-card-title\\\">\\n                      グループの総合力で<br>高品質×低価格を実現\\n                    </div>\\n                  </div>\\n                  <div class=\\\"reason-card-desc\\\">\\n                    さくらホームグループとして、不動産から新築・リフォームまで住まいに関するサービスを一手に提供しています。<br><br>\\n                    また、年間400棟以上の建築実績と多数の仕入れルートを活かし、資材コストを抑えながらも高品質な施工を可能にしています。<br><br>\\n                    さらに、中古住宅のリフォームによる再販で得た実践的なノウハウを活かし、最適なプランのご提案が可能です。\\n                  </div>\\n                </div>\\n              </div>\\n            </div>\\n\\n            <div class=\\\"reason-card\\\">\\n              <div class=\\\"reason-card-inner\\\">\\n                <div class=\\\"reason-card-bg\\\">\\n                  <img src=\\\"https://www.ricpro.com/images/rnwl/main/reason3.png\\\" alt=\\\"有資格者の確かな提案力\\\">\\n                </div>\\n                <div class=\\\"reason-card-content\\\">\\n                  <div class=\\\"reason-card-header\\\">\\n                    <div class=\\\"reason-card-num\\\">02</div>\\n                    <div class=\\\"reason-card-title\\\">\\n                      リフォームのプロによる<br>提案力×施工力\\n                    </div>\\n                  </div>\\n                  <div class=\\\"reason-card-desc\\\">\\n                    様々な資格を持つスタッフが豊富な知識で住環境をより快適にする外装・内装リフォームのアイデアをご提案します。<br><br>\\n                    さらに、外壁・屋根などの外装リフォームから、クロスの貼り替えやエアコンの取付といった内装リフォームまで幅広く自社職人が丁寧に対応。<br><br>\\n                    提案から施工まで自社一貫体制で安心の品質をお届けします。\\n                  </div>\\n                  <a href=\\\"https://www.ricpro.com/100/10031/\\\" class=\\\"reason-card-btn\\\">スタッフ紹介はこちら</a>\\n                </div>\\n              </div>\\n            </div>\\n            <div class=\\\"reason-card\\\">\\n              <div class=\\\"reason-card-inner\\\">\\n                <div class=\\\"reason-card-bg\\\">\\n                  <img src=\\\"https://www.ricpro.com/images/rnwl/main/reason1.png\\\" alt=\\\"地域密着20年以上\\\">\\n                </div>\\n                <div class=\\\"reason-card-content\\\">\\n                  <div class=\\\"reason-card-header\\\">\\n                    <div class=\\\"reason-card-num\\\">03</div>\\n                    <div class=\\\"reason-card-title\\\">\\n                      実績×保証で<br>長く安心な住まい\\n                    </div>\\n                  </div>\\n                  <div class=\\\"reason-card-desc\\\">\\n                    おかげさまでこれまでの施工実績は4,000棟以上。地域密着のきめ細かな対応が信頼につながっています。<br><br>\\n                    高い技術力に加え、万一に備えた最長10年の保証とアフターサービスをご用意。<br><br>\\n                    \",\n  \"message\": \"\\n        <div class=\\\"message-inner\\\">\\n          <div class=\\\"message-main\\\">\\n            <img src=\\\"https://www.ricpro.com/images/rnwl/main/section_img1.png\\\" alt=\\\"代表写真\\\" class=\\\"message-img\\\">\\n            <div class=\\\"message-text\\\">\\n              <h3>\\n                リフォーム専門店の確かな技術と、<br class=\\\"pc-only\\\">グループの総合力で応える。\\n              </h3>\\n              <p>\\n                私たちは、リフォーム専門店として20年以上にわたり地域の住まいを支えてきました。<br><br>累計4,000棟を超える施工で培った技術力と、空間づくりに対する深い知見が私たちの強みです。<br><br>さらに、不動産売買から建築までを手がける「さくらホームグループ」として、リフォームにとどまらない幅広いアフターサポートが可能です。<br><br>外装・内装リフォームをお考えの際は、安心して私たちにご相談ください。<br><br>豊富な経験と体制で、理想の住まいをかたちにします。\\n              </p>\\n              <div class=\\\"message-sign\\\">\\n                <span>リック・プロ株式会社　代表取締役</span><br>\\n                <img src=\\\"https://www.ricpro.com/images/rnwl/main/representative_sign.png\\\" alt=\\\"上濃俊介 署名\\\" class=\\\"representative-sign\\\">\\n              </div>\\n            </div>\\n          </div>\\n        </div>\\n      \",\n  \"voices\": \"\\n        <div class=\\\"voices-inner\\\">\\n          <div class=\\\"section-title\\\">\\n            <h2>お客様の声</h2>\\n            <img src=\\\"https://www.ricpro.com/images/rnwl/main/ricproman.png\\\" alt=\\\"リックプロマン\\\" class=\\\"section-illust\\\">\\n          </div>\\n          <div class=\\\"voices-list\\\">\\n            <div class=\\\"voice-card\\\">\\n              <img src=\\\"https://www.ricpro.com/images/rnwl/main/voice_img1.png\\\" alt=\\\"お客様1\\\" class=\\\"voice-card-img\\\">\\n              <div class=\\\"voice-tags\\\">\\n                <span class=\\\"voice-tag\\\">金沢市</span>\\n                <span class=\\\"voice-tag\\\">屋根</span>\\n              </div>\\n              <div class=\\\"voice-comment\\\">\\n                “全く知識が無かっ